generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  USER
  SUPERADMIN
}

enum ProjectStatus {
  active
  archived
}

enum MemberRole {
  VIEWER
  MANAGER
}

enum ProjectInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  googleId    String?    @unique
  passwordHash String?
  displayName String?
  avatarUrl   String?
  systemRole  SystemRole @default(USER)
  createdAt   DateTime   @default(now())
  memberships ProjectMembership[]
  ownedProjects Project[] @relation("OwnedProjects")
  auditLogs   AuditLog[] @relation("AuditActor")
  invitationsSent ProjectInvitation[] @relation("Inviter")
  projectLogs ProjectLog[] @relation("LogAuthor")
}

enum ProjectLogType {
  ENGINEERING
  EXPENSE
  INCOME
  REPORT
  COMPLETION
}

model Project {
  id           String            @id @default(uuid())
  parentId     String?
  parent       Project?          @relation("ProjectToChildren", fields: [parentId], references: [id])
  children     Project[]         @relation("ProjectToChildren")
  ownerUserId  String
  owner        User              @relation("OwnedProjects", fields: [ownerUserId], references: [id])
  name         String
  description  String?
  status       ProjectStatus     @default(active)
  path         String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  ProjectMembership[]
  invitations  ProjectInvitation[]
  auditLogs    AuditLog[]
  projectLogs  ProjectLog[]

  @@index([parentId])
  @@index([path])
}

model ProjectLog {
  id          String         @id @default(uuid())
  projectId   String
  userId      String
  type        ProjectLogType
  title       String
  content     String
  amount      Decimal?       @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?
  attachments Json?          // [{name: string, url: string}]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project     Project @relation(fields: [projectId], references: [id])
  author      User    @relation("LogAuthor", fields: [userId], references: [id])

  @@index([projectId, createdAt])
}

model ProjectMembership {
  projectId String
  userId    String
  role      MemberRole
  joinedAt  DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
  @@index([userId])
}

model ProjectInvitation {
  id            String           @id @default(uuid())
  projectId     String
  inviteeEmail  String
  role          MemberRole
  inviterUserId String
  status        ProjectInvitationStatus @default(PENDING)
  tokenHash     String
  expiresAt     DateTime
  createdAt     DateTime         @default(now())

  project       Project @relation(fields: [projectId], references: [id])
  inviter       User    @relation("Inviter", fields: [inviterUserId], references: [id])

  @@index([projectId])
  @@index([inviteeEmail])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  actionType  String
  entityType  String
  entityId    String
  projectId   String?
  payload     Json?
  createdAt   DateTime @default(now())

  actor       User     @relation("AuditActor", fields: [actorUserId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
}
